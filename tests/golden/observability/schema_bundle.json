      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
        },
        "kind": {
          "type": "string",
          "const": "observability.dashboard"
        },
        "name": {
          "type": "string",
          "minLength": 1
