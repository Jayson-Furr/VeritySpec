            "count",
            "sum",
            "average",
            "min",
            "max",
            "percentile",
            "rate",
            "gauge"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "target"
            ],
            "properties": {
              "type": {
                "type": "string"
              },
              "target": {
                "type": "string"
              },
              "required": {
                "type": "boolean",
                "default": true
              }
            }
          },
          "default": []
        }
      }
    },
    "observability.telemetry": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
