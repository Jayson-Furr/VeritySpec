          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "ready",
            "deprecated",
            "removed"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "enum": [
            "engineering",
            "operations",
            "support",
            "leadership",
            "external"
          ]
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "target"
            ],
            "properties": {
              "type": {
                "type": "string"
              },
              "target": {
                "type": "string"
              },
              "required": {
                "type": "boolean",
                "default": true
              }
            }
          },
          "default": []
        }
      }
    },
    "observability.metric": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
