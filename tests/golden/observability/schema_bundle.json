{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VeritySpec Schema Bundle",
  "packs": [
    "verity.core",
    "verity.pack.observability"
  ],
  "schemas": {
    "observability.alert": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://verityspec.org/schemas/v0.1/observability/observability-alert.schema.json",
      "title": "Observability Alert",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "name",
        "status",
        "owner",
        "description",
        "severity",
        "condition",
        "ownerTeam"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
        },
        "kind": {
          "type": "string",
          "const": "observability.alert"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "ready",
            "deprecated",
            "removed"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "critical"
          ]
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "ownerTeam": {
          "type": "string",
          "minLength": 1
        },
        "runbook": {
          "type": "string"
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "target"
            ],
            "properties": {
              "type": {
                "type": "string"
              },
              "target": {
                "type": "string"
              },
              "required": {
                "type": "boolean",
                "default": true
              }
            }
          },
          "default": []
        }
      }
    },
    "observability.dashboard": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://verityspec.org/schemas/v0.1/observability/observability-dashboard.schema.json",
