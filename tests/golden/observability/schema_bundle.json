          "minLength": 1
        },
        "payloadSchema": {
          "type": "string",
          "minLength": 1
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "target"
            ],
            "properties": {
              "type": {
