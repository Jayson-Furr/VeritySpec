{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/unity/unity-scene.schema.json",
  "title": "Unity Scene",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "scenePath",
    "sceneRole",
    "loadMode",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "unity.scene"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "scenePath": {
      "type": "string",
      "minLength": 1
    },
    "sceneRole": {
      "type": "string",
      "enum": ["prototype", "menu", "gameplay", "loading", "test", "persistent", "other"]
    },
    "loadMode": {
      "type": "string",
      "enum": ["single", "additive", "addressable", "other"]
    },
    "includedInBuild": {
      "type": "boolean",
      "default": true
    },
    "notes": {
      "type": "string"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
