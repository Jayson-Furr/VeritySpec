{
  "records": [
    {
      "id": "product.orders",
      "kind": "product",
      "name": "Orders Product",
      "description": "Order management contract used for impact reporting.",
      "status": "ready",
      "owner": "commerce",
      "version": "1.1.0",
      "references": [
        {
          "type": "exposes",
          "target": "api.orders.list"
        },
        {
          "type": "securedBy",
          "target": "security.control.order_access"
        },
        {
          "type": "emits",
          "target": "event.orders.exported"
        }
      ]
    },
    {
      "id": "schema.order_list",
      "kind": "schema.object",
      "name": "Order List",
      "description": "Order list response schema.",
      "status": "ready",
      "owner": "commerce",
      "jsonSchema": {
        "type": "object",
        "required": [
          "orders",
          "total"
        ],
        "properties": {
          "orders": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Order"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "references": []
    },
    {
      "id": "schema.order_event",
      "kind": "schema.object",
      "name": "Order Event",
      "description": "Order export event payload schema.",
      "status": "ready",
      "owner": "commerce",
      "jsonSchema": {
        "type": "object",
        "required": [
          "orderId",
          "exportedAt"
        ],
        "properties": {
          "orderId": {
            "type": "string"
          },
          "exportedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "references": []
    },
    {
      "id": "api.orders.list",
      "kind": "api.endpoint",
      "name": "List Orders",
      "description": "Lists orders for release-impact testing.",
      "status": "ready",
      "owner": "commerce-api",
      "method": "GET",
      "path": "/v2/orders",
      "summary": "List orders.",
      "responses": [
        {
          "statusCode": 200,
          "description": "Orders returned.",
          "schema": "schema.order_list"
        }
      ],
      "references": [
        {
          "type": "emits",
          "target": "event.orders.exported"
        }
      ]
    },
    {
      "id": "event.orders.exported",
      "kind": "event.message",
      "name": "Orders Exported",
      "description": "Published when an order export completes.",
      "status": "ready",
      "owner": "commerce-events",
      "topic": "orders.exported",
      "payloadSchema": "schema.order_event",
      "references": []
    },
    {
      "id": "security.control.order_access",
      "kind": "security.control",
      "name": "Order Access Control",
      "description": "Restricts order reads to authorized callers.",
      "status": "ready",
      "owner": "security",
      "category": "authorization",
      "controlType": "preventive",
      "riskLevel": "high",
      "objective": "Prevent unauthorized order access.",
      "coverage": "verified",
      "verification": {
        "method": "automated-test",
        "evidence": "tests/security/test_order_access.py::test_order_access"
      },
      "references": [
        {
          "type": "appliesTo",
          "target": "api.orders.list"
        },
        {
          "type": "appliesTo",
          "target": "schema.order_list"
        }
      ]
    }
  ]
}
