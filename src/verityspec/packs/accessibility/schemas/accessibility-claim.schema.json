{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/accessibility/accessibility-claim.schema.json",
  "title": "Accessibility Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "standard",
    "criterion",
    "level",
    "userNeed",
    "surface",
    "impact",
    "coverage",
    "verification",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "accessibility.claim"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "standard": {
      "type": "string",
      "enum": ["wcag-2.1", "wcag-2.2", "section-508", "platform-guideline", "internal"]
    },
    "criterion": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "type": "string",
      "enum": ["a", "aa", "aaa", "not-applicable"]
    },
    "userNeed": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "type": "string",
      "minLength": 1
    },
    "impact": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "coverage": {
      "type": "string",
      "enum": ["planned", "partial", "implemented", "verified"]
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "evidence"],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "manual-review",
            "automated-test",
            "assistive-technology-test",
            "design-review",
            "not-verified"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "lastVerified": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "assistiveTechnologies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
