{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/game-core/game-mode.schema.json",
  "title": "Game Mode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "modeType",
    "summary",
    "playerCount",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "game.mode"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "modeType": {
      "type": "string",
      "enum": [
        "single-player",
        "co-op",
        "competitive",
        "asymmetric",
        "sandbox",
        "party",
        "other"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "playerCount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 1
        },
        "max": {
          "type": "integer",
          "minimum": 1
        },
        "recommended": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "sessionLengthMinutes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 1
        },
        "max": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
