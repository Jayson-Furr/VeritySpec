{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/deployment/deployment-runtime.schema.json",
  "title": "Deployment Runtime",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "runtimeType",
    "runtimeName",
    "version",
    "artifactType"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "deployment.runtime"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "runtimeType": {
      "type": "string",
      "enum": [
        "container",
        "serverless",
        "vm",
        "static-site",
        "mobile",
        "desktop",
        "managed-service",
        "other"
      ]
    },
    "runtimeName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "artifactType": {
      "type": "string",
      "enum": [
        "container-image",
        "function",
        "package",
        "static-assets",
        "binary",
        "mobile-build",
        "configuration",
        "other"
      ]
    },
    "language": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
