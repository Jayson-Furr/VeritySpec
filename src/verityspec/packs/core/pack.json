{
  "id": "verity.core",
  "version": "0.1.0",
  "name": "VeritySpec Core",
  "description": "Core product-contract records shared by every VeritySpec workspace.",
  "schemas": [
    {
      "kind": "product",
      "path": "schemas/product.schema.json"
    },
    {
      "kind": "schema.object",
      "path": "schemas/schema-object.schema.json"
    }
  ],
  "readinessGates": [
    {
      "id": "core.product.release",
      "kind": "product",
      "required": ["owner", "name", "version", "description"]
    },
    {
      "id": "core.schema.release",
      "kind": "schema.object",
      "required": ["owner", "name", "jsonSchema"]
    }
  ],
  "referenceRules": [
    {
      "sourceKind": "product",
      "relationship": "exposes",
      "targetKind": "api.endpoint"
    },
    {
      "sourceKind": "product",
      "relationship": "emits",
      "targetKind": "event.message"
    },
    {
      "sourceKind": "product",
      "relationship": "ships",
      "targetKind": "cli.command"
    },
    {
      "sourceKind": "schema.object",
      "relationship": "contains",
      "targetKind": "schema.object"
    }
  ],
  "generators": [
    {
      "id": "schema-bundle",
      "name": "Schema Bundle",
      "description": "Emit JSON Schema definitions for core product and schema records.",
      "artifactType": "schema-bundle",
      "outputFormats": ["json"],
      "recordKinds": ["product", "schema.object"]
    },
    {
      "id": "coverage-dashboard",
      "name": "Coverage Dashboard",
      "description": "Summarize cross-pack product-surface coverage for release review.",
      "artifactType": "report",
      "outputFormats": ["json", "markdown"],
      "recordKinds": ["product", "schema.object"]
    },
    {
      "id": "product-impact",
      "name": "Product Impact Report",
      "description": "Expand changed records into upstream and downstream graph impacts for release review.",
      "artifactType": "report",
      "outputFormats": ["json"],
      "recordKinds": ["product", "schema.object"]
    },
    {
      "id": "pack-capability-index",
      "name": "Pack Capability Index",
      "description": "Summarize loaded pack schemas, readiness gates, reference rules, and generators for registry review.",
      "artifactType": "report",
      "outputFormats": ["json"],
      "recordKinds": ["product", "schema.object"]
    }
  ]
}
