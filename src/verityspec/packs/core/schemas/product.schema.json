{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/core/product.schema.json",
  "title": "Product",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "name", "status", "owner", "version"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "product"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}

