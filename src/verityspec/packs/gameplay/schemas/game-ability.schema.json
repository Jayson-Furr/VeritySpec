{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/gameplay/game-ability.schema.json",
  "title": "Game Ability",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "abilityType",
    "activation",
    "effectSummary",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "game.ability"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "abilityType": {
      "type": "string",
      "enum": ["active", "passive", "ultimate", "movement", "defensive", "utility", "other"]
    },
    "activation": {
      "type": "string",
      "enum": ["manual", "automatic", "triggered", "contextual", "passive", "other"]
    },
    "effectSummary": {
      "type": "string",
      "minLength": 1
    },
    "cooldownSeconds": {
      "type": "number",
      "minimum": 0
    },
    "resourceCost": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
