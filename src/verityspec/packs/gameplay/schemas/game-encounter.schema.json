{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/gameplay/game-encounter.schema.json",
  "title": "Game Encounter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "encounterType",
    "difficulty",
    "objective",
    "participantRefs",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "game.encounter"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "encounterType": {
      "type": "string",
      "enum": ["combat", "exploration", "puzzle", "boss", "tutorial", "social", "liveops", "other"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["tutorial", "easy", "normal", "hard", "expert", "variable"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "location": {
      "type": "string"
    },
    "participantRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
