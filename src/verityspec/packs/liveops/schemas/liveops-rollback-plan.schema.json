{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/liveops.rollback-plan.schema.json",
  "title": "LiveOps Rollback Plan",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "rollbackTrigger",
    "rollbackMethod",
    "decisionOwner"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "liveops.rollback-plan"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "rollbackTrigger": {
      "type": "string",
      "minLength": 1
    },
    "rollbackMethod": {
      "type": "string",
      "minLength": 1
    },
    "decisionOwner": {
      "type": "string",
      "minLength": 1
    },
    "maxRollbackTime": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
