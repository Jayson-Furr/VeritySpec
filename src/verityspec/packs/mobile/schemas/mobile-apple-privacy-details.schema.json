{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/mobile.apple-privacy-details.schema.json",
  "title": "Apple Privacy Details",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "dataCategories",
    "collectionPosture",
    "trackingPosture"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "mobile.apple-privacy-details"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "dataCategories": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "collectionPosture": {
      "type": "string",
      "enum": [
        "none",
        "collected",
        "not-collected",
        "unknown",
        "other"
      ]
    },
    "trackingPosture": {
      "type": "string",
      "enum": [
        "no-tracking",
        "tracking",
        "not-applicable",
        "unknown",
        "other"
      ]
    },
    "nutritionLabelStatus": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "submitted",
        "other"
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
