{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/observability/observability-metric.schema.json",
  "title": "Observability Metric",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "name", "status", "owner", "description", "metricName", "unit", "aggregation"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "observability.metric"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "metricName": {
      "type": "string",
      "minLength": 1
    },
    "unit": {
      "type": "string",
      "minLength": 1
    },
    "aggregation": {
      "type": "string",
      "enum": ["count", "sum", "average", "min", "max", "percentile", "rate", "gauge"]
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
