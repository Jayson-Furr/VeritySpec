{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.dev/schemas/unreal.plugin.json",
  "title": "unreal.plugin record",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "pluginName",
    "version",
    "source",
    "purpose"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "kind": {
      "type": "string",
      "const": "unreal.plugin"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "pluginName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "pluginPath": {
      "type": "string"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "enabledByDefault": {
      "type": "boolean"
    },
    "moduleRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repository": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
