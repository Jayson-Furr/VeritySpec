{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.dev/schemas/unreal.input-action.json",
  "title": "unreal.input-action record",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "actionName",
    "valueType",
    "deviceTypes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "kind": {
      "type": "string",
      "const": "unreal.input-action"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "actionName": {
      "type": "string",
      "minLength": 1
    },
    "valueType": {
      "type": "string",
      "minLength": 1
    },
    "deviceTypes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "mappingContext": {
      "type": "string"
    },
    "handledByRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repository": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
