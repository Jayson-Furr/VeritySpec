{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.dev/schemas/unreal.validation-runner.json",
  "title": "unreal.validation-runner record",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "runnerType",
    "command"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "kind": {
      "type": "string",
      "const": "unreal.validation-runner"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "runnerType": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "scannerRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "readinessDashboardRef": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "required": [
          "runnerType"
        ],
        "properties": {
          "runnerType": {
            "not": {
              "const": "device-smoke"
            }
          }
        }
      },
      "then": {
        "required": [
          "scannerRefs"
        ],
        "properties": {
          "scannerRefs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
