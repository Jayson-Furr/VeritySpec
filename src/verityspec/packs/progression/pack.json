      "targetKind": "progression.level"
    },
    {
      "sourceKind": "progression.gate",
      "relationship": "usesCurrency",
      "targetKind": "economy.currency"
    },
    {
      "sourceKind": "progression.gate",
      "relationship": "requiresEvidence",
      "targetKind": "evidence.requirement"
    },
    {
      "sourceKind": "economy.reward",
      "relationship": "grantsProgression",
      "targetKind": "progression.xp-model"
    },
    {
      "sourceKind": "liveops.config",
      "relationship": "tunesProgression",
      "targetKind": "progression.track"
    },
    {
      "sourceKind": "unity.project",
      "relationship": "implementsProgression",
      "targetKind": "progression.track"
    },
    {
      "sourceKind": "godot.project",
