{
  "id": "verity.pack.progression",
  "version": "0.45.0",
  "name": "VeritySpec Progression Pack",
  "description": "Game progression XP model, level, unlock, track, and gate records for executable progression product-contract coverage.",
  "schemas": [
    {
      "kind": "progression.xp-model",
      "path": "schemas/progression-xp-model.schema.json"
    },
    {
      "kind": "progression.level",
      "path": "schemas/progression-level.schema.json"
    },
    {
      "kind": "progression.unlock",
      "path": "schemas/progression-unlock.schema.json"
    },
    {
      "kind": "progression.track",
      "path": "schemas/progression-track.schema.json"
    },
    {
      "kind": "progression.gate",
      "path": "schemas/progression-gate.schema.json"
    }
  ],
  "readinessGates": [
    {
      "id": "progression.xp-model.ready",
      "kind": "progression.xp-model",
      "required": [
        "owner",
        "name",
        "description",
        "xpSource",
        "scaleModel",
        "formula",
        "maxLevel"
      ]
    },
    {
      "id": "progression.level.ready",
      "kind": "progression.level",
      "required": [
        "owner",
        "name",
        "description",
        "trackRef",
        "levelNumber",
        "xpRequired"
      ],
      "minItems": {
        "references": 1
      }
    },
    {
      "id": "progression.unlock.ready",
      "kind": "progression.unlock",
      "required": [
        "owner",
        "name",
        "description",
        "unlockType",
        "unlockTargetRef",
        "trackRef"
      ],
      "minItems": {
        "references": 1
      }
    },
    {
      "id": "progression.track.ready",
      "kind": "progression.track",
      "required": [
        "owner",
        "name",
        "description",
        "trackType",
        "xpModelRef",
        "levelRefs",
        "unlockRefs"
      ],
      "minItems": {
        "levelRefs": 1,
        "unlockRefs": 1,
        "references": 3
      }
    },
    {
      "id": "progression.gate.ready",
      "kind": "progression.gate",
      "required": [
        "owner",
        "name",
        "description",
        "gateType",
        "condition",
        "trackRef"
      ],
      "minItems": {
        "references": 1
      }
    }
  ],
  "referenceRules": [
    {
      "sourceKind": "product",
      "relationship": "hasProgressionTrack",
      "targetKind": "progression.track"
    },
    {
      "sourceKind": "game.product",
      "relationship": "hasProgressionTrack",
      "targetKind": "progression.track"
    },
    {
      "sourceKind": "game.loop",
      "relationship": "usesProgressionTrack",
      "targetKind": "progression.track"
    },
    {
      "sourceKind": "game.mode",
      "relationship": "usesProgressionTrack",
      "targetKind": "progression.track"
    },
    {
      "sourceKind": "game.prototype-scope",
      "relationship": "validatesProgression",
      "targetKind": "progression.track"
    },
    {
      "sourceKind": "progression.track",
      "relationship": "usesXpModel",
      "targetKind": "progression.xp-model"
    },
    {
      "sourceKind": "progression.track",
      "relationship": "hasLevel",
      "targetKind": "progression.level"
    },
    {
      "sourceKind": "progression.track",
      "relationship": "hasUnlock",
      "targetKind": "progression.unlock"
    },
    {
      "sourceKind": "progression.track",
