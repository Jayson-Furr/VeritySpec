      "targetKind": "progression.gate"
    },
    {
      "sourceKind": "progression.level",
      "relationship": "belongsToTrack",
      "targetKind": "progression.track"
    },
    {
      "sourceKind": "progression.level",
      "relationship": "unlocks",
      "targetKind": "progression.unlock"
    },
    {
      "sourceKind": "progression.level",
      "relationship": "grantsReward",
      "targetKind": "economy.reward"
    },
    {
      "sourceKind": "progression.unlock",
