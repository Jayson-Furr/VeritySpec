      "targetKind": "game.content-item"
    },
    {
      "sourceKind": "progression.unlock",
      "relationship": "targetsAbility",
      "targetKind": "game.ability"
    },
    {
      "sourceKind": "progression.unlock",
      "relationship": "gatedBy",
      "targetKind": "progression.gate"
    },
    {
      "sourceKind": "progression.gate",
