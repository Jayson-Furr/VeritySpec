      "relationship": "implementsProgression",
      "targetKind": "progression.track"
    }
  ],
  "generators": [
    {
      "id": "schema-bundle",
      "name": "Schema Bundle",
      "description": "Emit JSON Schema definitions for progression records.",
      "artifactType": "schema-bundle",
      "outputFormats": [
        "json"
      ],
      "recordKinds": [
        "progression.xp-model",
        "progression.level",
        "progression.unlock",
        "progression.track",
        "progression.gate"
      ]
    },
    {
      "id": "coverage-dashboard",
      "name": "Coverage Dashboard",
      "description": "Count progression records as a first-class product surface.",
      "artifactType": "report",
      "outputFormats": [
        "json",
        "markdown"
      ],
      "recordKinds": [
        "progression.xp-model",
        "progression.level",
        "progression.unlock",
        "progression.track",
        "progression.gate"
      ]
    }
  ]
}
