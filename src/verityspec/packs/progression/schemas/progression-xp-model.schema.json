{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/progression.xp-model.schema.json",
  "title": "Progression XP Model",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "xpSource",
    "scaleModel",
    "formula",
    "maxLevel"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "progression.xp-model"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "xpSource": {
      "type": "string",
      "enum": [
        "gameplay",
        "quest",
        "economy",
        "liveops",
        "manual",
        "other"
      ]
    },
    "scaleModel": {
      "type": "string",
      "enum": [
        "linear",
        "curve",
        "table",
        "milestone",
        "other"
      ]
    },
    "formula": {
      "type": "string",
      "minLength": 1
    },
    "maxLevel": {
      "type": "integer",
      "minimum": 1
    },
    "xpUnitName": {
      "type": "string",
      "minLength": 1
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tuningNotes": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
