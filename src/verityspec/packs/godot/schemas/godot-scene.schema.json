{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/godot/godot-scene.schema.json",
  "title": "Godot Scene",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "scenePath",
    "sceneRole",
    "rootNode",
    "loadMode",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "godot.scene"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "scenePath": {
      "type": "string",
      "minLength": 1
    },
    "sceneRole": {
      "type": "string",
      "enum": [
        "prototype",
        "gameplay",
        "ui",
        "menu",
        "test",
        "tool",
        "other"
      ]
    },
    "rootNode": {
      "type": "string",
      "minLength": 1
    },
    "loadMode": {
      "type": "string",
      "enum": [
        "main",
        "instanced",
        "autoload",
        "tool",
        "other"
      ]
    },
    "includedInExport": {
      "type": "boolean",
      "default": true
    },
    "notes": {
      "type": "string"
    },
    "references": {
      "$ref": "#/$defs/references"
    }
  },
  "$defs": {
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "target"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
