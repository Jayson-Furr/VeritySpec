{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/godot/godot-export-preset.schema.json",
  "title": "Godot Export Preset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "presetName",
    "platform",
    "outputPath",
    "scenes",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "godot.export-preset"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "presetName": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "enum": [
        "windows",
        "macos",
        "linux",
        "web",
        "android",
        "ios",
        "console",
        "other"
      ]
    },
    "outputPath": {
      "type": "string",
      "minLength": 1
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "debugExport": {
      "type": "boolean",
      "default": false
    },
    "references": {
      "$ref": "#/$defs/references"
    }
  },
  "$defs": {
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "target"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
