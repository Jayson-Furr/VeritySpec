{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/godot/godot-validation-runner.schema.json",
  "title": "Godot Validation Runner",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "runnerType",
    "command",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "godot.validation-runner"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "runnerType": {
      "type": "string",
      "enum": [
        "editor",
        "ci",
        "local",
        "precommit",
        "device-smoke",
        "other"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "scannerRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "readinessDashboardRef": {
      "type": "string"
    },
    "references": {
      "$ref": "#/$defs/references"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "runnerType"
        ],
        "properties": {
          "runnerType": {
            "not": {
              "const": "device-smoke"
            }
          }
        }
      },
      "then": {
        "required": [
          "scannerRefs"
        ],
        "properties": {
          "scannerRefs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "target"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
