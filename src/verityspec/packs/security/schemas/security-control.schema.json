{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/security/security-control.schema.json",
  "title": "Security Control",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "category",
    "controlType",
    "riskLevel",
    "objective",
    "coverage",
    "verification",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "security.control"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "authentication",
        "authorization",
        "data-protection",
        "input-validation",
        "audit-logging",
        "secrets-management",
        "dependency-management",
        "availability",
        "privacy",
        "compliance",
        "other"
      ]
    },
    "controlType": {
      "type": "string",
      "enum": ["preventive", "detective", "corrective", "compensating"]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "coverage": {
      "type": "string",
      "enum": ["planned", "partial", "implemented", "verified"]
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "evidence"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["manual-review", "automated-test", "monitoring", "external-audit", "not-verified"]
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "lastVerified": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reviewCadenceDays": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
