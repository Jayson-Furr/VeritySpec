{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/evidence.test.schema.json",
  "title": "Evidence Test",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "subjectRef",
    "testType",
    "command",
    "result",
    "evidenceUri"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "evidence.test"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "minItems": 1
    },
    "subjectRef": {
      "type": "string",
      "minLength": 1
    },
    "subjectKind": {
      "type": "string",
      "minLength": 1
    },
    "testType": {
      "type": "string",
      "enum": [
        "unit",
        "integration",
        "e2e",
        "unity-edit-mode",
        "unity-play-mode",
        "godot",
        "unreal",
        "other"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "passing",
        "failing",
        "skipped",
        "inconclusive"
      ]
    },
    "evidenceUri": {
      "type": "string",
      "minLength": 1
    },
    "executedAt": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
