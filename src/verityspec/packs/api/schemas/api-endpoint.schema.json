{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/api/api-endpoint.schema.json",
  "title": "API Endpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "name", "status", "owner", "method", "path", "responses"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "api.endpoint"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
    },
    "path": {
      "type": "string",
      "pattern": "^/"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "requestSchema": {
      "type": "string"
    },
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statusCode", "description"],
        "properties": {
          "statusCode": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 100,
                "maximum": 599
              },
              {
                "type": "string",
                "pattern": "^[1-5][0-9][0-9]$"
              }
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "schema": {
            "type": "string"
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}

