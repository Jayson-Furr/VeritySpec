{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/product-delivery/operations.model.schema.json",
  "title": "Operations Model",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "operatingModel",
    "incidentPolicy",
    "monitoringPolicy"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "operations.model"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "minItems": 1
    },
    "operatingModel": {
      "type": "string",
      "enum": [
        "none",
        "maintained",
        "live-service",
        "scheduled",
        "on-demand",
        "other"
      ]
    },
    "incidentPolicy": {
      "type": "string",
      "minLength": 1
    },
    "monitoringPolicy": {
      "type": "string",
      "minLength": 1
    },
    "runbookPath": {
      "type": "string",
      "minLength": 1
    },
    "escalationOwner": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
