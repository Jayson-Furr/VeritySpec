{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/product-delivery/product.scope.schema.json",
  "title": "Product Scope",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "scopeType",
    "productArea",
    "intent"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "product.scope"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "minItems": 3
    },
    "scopeType": {
      "type": "string",
      "enum": [
        "repository",
        "toolkit",
        "game",
        "service",
        "library",
        "portfolio",
        "other"
      ]
    },
    "productArea": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "outOfScope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "targetAudience": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "statusTargets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
