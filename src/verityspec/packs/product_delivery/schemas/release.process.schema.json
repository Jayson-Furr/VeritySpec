{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/product-delivery/release.process.schema.json",
  "title": "Release Process",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "releaseType",
    "branchStrategy",
    "tagPolicy",
    "approvalPolicy",
    "readinessProfileRefs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "release.process"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "minItems": 1
    },
    "releaseType": {
      "type": "string",
      "enum": [
        "alpha",
        "beta",
        "stable",
        "maintenance",
        "archive",
        "other"
      ]
    },
    "branchStrategy": {
      "type": "string",
      "minLength": 1
    },
    "tagPolicy": {
      "type": "string",
      "minLength": 1
    },
    "approvalPolicy": {
      "type": "string",
      "minLength": 1
    },
    "artifactPolicy": {
      "type": "string",
      "minLength": 1
    },
    "readinessProfileRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
