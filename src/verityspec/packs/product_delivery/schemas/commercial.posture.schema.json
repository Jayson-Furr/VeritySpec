{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/product-delivery/commercial.posture.schema.json",
  "title": "Commercial Posture",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "posture",
    "visibility",
    "distributionModel"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "commercial.posture"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "posture": {
      "type": "string",
      "enum": [
        "private-proprietary",
        "public-open-source",
        "internal",
        "commercial",
        "non-commercial",
        "other"
      ]
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "public",
        "internal"
      ]
    },
    "distributionModel": {
      "type": "string",
      "enum": [
        "private-alpha",
        "public-release",
        "marketplace-candidate",
        "internal-tool",
        "open-source",
        "other"
      ]
    },
    "monetization": {
      "type": "string",
      "enum": [
        "none",
        "paid",
        "ads",
        "iap",
        "subscription",
        "mixed",
        "other"
      ]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "policyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
