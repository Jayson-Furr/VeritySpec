{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/product-delivery/archive.policy.schema.json",
  "title": "Archive Policy",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "archiveTrigger",
    "retentionPolicy",
    "archiveLocation"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "archive.policy"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "archiveTrigger": {
      "type": "string",
      "enum": [
        "on-sunset",
        "on-major-version",
        "on-decommission",
        "manual",
        "other"
      ]
    },
    "retentionPolicy": {
      "type": "string",
      "minLength": 1
    },
    "archiveLocation": {
      "type": "string",
      "minLength": 1
    },
    "artifactManifest": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
