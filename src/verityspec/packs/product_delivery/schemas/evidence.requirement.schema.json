{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/product-delivery/evidence.requirement.schema.json",
  "title": "Evidence Requirement",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "evidenceType",
    "subjectKind",
    "requiredForStatus",
    "verificationMethod"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "evidence.requirement"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "evidenceType": {
      "type": "string",
      "enum": [
        "test",
        "ci-run",
        "review",
        "document",
        "artifact",
        "screenshot",
        "video",
        "report",
        "approval",
        "other"
      ]
    },
    "subjectKind": {
      "type": "string",
      "minLength": 1
    },
    "requiredForStatus": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "verificationMethod": {
      "type": "string",
      "enum": [
        "manual-review",
        "automated-check",
        "artifact-exists",
        "ci-status",
        "other"
      ]
    },
    "evidencePath": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
