{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/product-delivery/project-management.model.schema.json",
  "title": "Project Management Model",
  "type": "object",
  "required": [
    "id",
    "kind",
    "name",
    "description",
    "status",
    "owner",
    "system",
    "planningModel",
    "issuePolicy",
    "projectPolicy",
    "milestonePolicy"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "const": "project-management.model"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "ready",
        "deprecated",
        "removed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "minItems": 1
    },
    "system": {
      "type": "string",
      "enum": [
        "github",
        "jira",
        "linear",
        "azure-devops",
        "other"
      ]
    },
    "planningModel": {
      "type": "string",
      "enum": [
        "issues-projects-milestones",
        "kanban",
        "scrum",
        "roadmap",
        "other"
      ]
    },
    "issuePolicy": {
      "type": "string",
      "minLength": 1
    },
    "projectPolicy": {
      "type": "string",
      "minLength": 1
    },
    "milestonePolicy": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "boardUrl": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "required": [
        "type",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}
