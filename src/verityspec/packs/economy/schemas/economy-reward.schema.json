{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/economy/economy-reward.schema.json",
  "title": "Economy Reward",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "name",
    "status",
    "owner",
    "description",
    "rewardType",
    "grants",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "const": "economy.reward"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "ready", "deprecated", "removed"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "rewardType": {
      "type": "string",
      "enum": ["encounter", "quest", "login", "offer", "level", "progression", "liveops", "other"]
    },
    "grants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["targetRef", "quantity"],
        "properties": {
          "targetRef": {
            "type": "string",
            "minLength": 1
          },
          "targetKind": {
            "type": "string",
            "enum": ["economy.currency", "game.content-item", "game.loot-table", "other"]
          },
          "quantity": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "claimLimit": {
      "type": "integer",
      "minimum": 1
    },
    "tuningNotes": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "$ref": "#/$defs/references"
    }
  },
  "$defs": {
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "default": []
    }
  }
}
