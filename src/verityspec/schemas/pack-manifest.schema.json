{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verityspec.org/schemas/v0.1/pack-manifest.schema.json",
  "title": "VeritySpec Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "name", "description", "schemas", "readinessGates", "generators"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^verity(?:\\.pack)?\\.[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^schemas/.+\\.schema\\.json$"
          }
        }
      }
    },
    "readinessGates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "required"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "minItems": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          },
          "requireVerifiedForRisk": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          }
        }
      }
    },
    "referenceRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceKind", "relationship", "targetKind"],
        "properties": {
          "sourceKind": {
            "type": "string",
            "minLength": 1
          },
          "relationship": {
            "type": "string",
            "minLength": 1
          },
          "targetKind": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "default": []
    },
    "generators": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

