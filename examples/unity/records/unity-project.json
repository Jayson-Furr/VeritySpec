{
  "id": "unity.project.dream_extraction",
  "kind": "unity.project",
  "name": "Dream Extraction Unity Project",
  "description": "Unity project contract for the first Dream Extraction prototype.",
  "status": "ready",
  "owner": "unity-engineering",
  "unityVersion": "2022.3 LTS",
  "projectPath": "unity/DreamExtraction",
  "renderPipeline": "urp",
  "scriptingBackend": "il2cpp",
  "targetPlatforms": [
    "pc"
  ],
  "assemblyDefinitionPaths": [
    "Assets/DreamExtraction/DreamExtraction.Runtime.asmdef"
  ],
  "references": [
    {
      "type": "usesPackage",
      "target": "unity.package.input_system"
    },
    {
      "type": "usesSharedLibrary",
      "target": "unity.shared-library.dream_runtime"
    },
    {
      "type": "containsScene",
      "target": "unity.scene.prototype_zone"
    },
    {
      "type": "containsPrefab",
      "target": "unity.prefab.player_avatar"
    },
    {
      "type": "declaresAssembly",
      "target": "unity.asmdef.dream_runtime"
    },
    {
      "type": "buildsFor",
      "target": "unity.build-target.pc_development"
    }
  ]
}
